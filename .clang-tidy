# -readability-uppercase-literal-suffix : I prefer 16u, 10.0f, etc.
# -readability-redundant-member-init    : DMI suppresses -Wmissing-field-initializers
# -readability-use-concise-preprocessor-directives : defined() is not hard to write
# -modernize-return-braced-init-list : Explicit constructor returns are more clear IMO
Checks: |
  bugprone-*,
  -bugprone-easily-swappable-parameters,
  -bugprone-narrowing-conversions,

  performance-*,

  modernize-*,
  -modernize-use-trailing-return-type,
  -modernize-avoid-c-arrays,
  -modernize-use-nodiscard,
  -modernize-return-braced-init-list,

  readability-*,
  -readability-magic-numbers,
  -readability-identifier-length,
  -readability-function-cognitive-complexity,
  -readability-else-after-return,
  -readability-uppercase-literal-suffix,
  -readability-redundant-member-init,
  -readability-use-concise-preprocessor-directives,

  concurrency-*,

  misc-const-correctness,
  misc-definitions-in-headers,
  misc-misplaced-const,
  misc-redundant-expression,
  misc-unused-parameters,

  cppcoreguidelines-pro-type-member-init,
  cppcoreguidelines-pro-type-static-cast-downcast,
  cppcoreguidelines-slicing,
  cppcoreguidelines-special-member-functions

WarningsAsErrors: ''

# Check .h,.hpp, and .inl includes ONLY if they are NOT part of a /vendor/* path.
HeaderFilterRegex: '^(?!.*/vendor/).*\.(h|hpp|inl)$'

FormatStyle: file
